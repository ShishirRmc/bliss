# =============================================================================
# Blys AI Assessment — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Options: "openai" | "gemini" | "ollama_cloud"
LLM_PROVIDER=openai

# --- API Keys (only the key for your chosen provider is required) -----------
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...
OLLAMA_API_KEY=...

# --- Sentiment Analysis Provider --------------------------------------------
# Options: "huggingface" | "llm"
# "huggingface" uses local DistilBERT on CPU (no API cost, ~260MB download)
# "llm" uses the selected LLM_PROVIDER (API cost, no local download)
SENTIMENT_PROVIDER=huggingface

# --- Embedding Model --------------------------------------------------------
# Local sentence-transformers model for RAG embeddings (runs on CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed origins. Use "*" for local dev only.
# Example: CORS_ORIGINS=https://app.blys.com.au,https://staging.blys.com.au
CORS_ORIGINS=*
